<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Katalog Buku & Penulis</title>
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans p-6 min-h-screen">

  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold text-blue-600">📚 Katalog Buku & Penulis</h1>
      <p class="text-gray-600">Integrasi EJS Template Engine & API Express.js</p>
    </header>

    <!-- Tombol Navigasi / Filter -->
    <div class="flex justify-center gap-3 mb-8">
      <button onclick="switchTab('all')" id="btn-all" class="bg-gray-900 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer">
        Tampilkan Semua
      </button>
      <button onclick="switchTab('books')" id="btn-books" class="bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer">
        Daftar Buku
      </button>
      <button onclick="switchTab('authors')" id="btn-authors" class="bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer">
        Daftar Penulis
      </button>
    </div>

    <!-- SATU KOTAK BESAR UTAMA -->
    <div class="bg-white p-6 rounded-lg shadow-md">
      
      <!-- Judul Kotak & Tombol Tambah Buku -->
      <div class="flex justify-between items-center mb-4 border-b pb-2">
        <h2 id="box-title" class="text-xl font-semibold text-purple-600">Semua Data (Buku & Penulis)</h2>
        <a href="/buku/tambah" class="bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-2 rounded-lg font-medium transition shadow">
          + Tambah Buku
        </a>
      </div>
      
      <!-- Wadah Konten Dinamis -->
      <div id="main-container" class="space-y-6">
        <p class="text-gray-500 italic">Memuat data dari API...</p>
      </div>

    </div>
  </div>

  <!-- SCRIPT UTAMA UNTUK FETCH API & RENDER STYLE ASLI ANDA -->
  <script>
    let globalBooks = [];
    let globalAuthors = [];
    let currentTab = 'all'; // 'all', 'books', atau 'authors'

    // Fungsi untuk mengambil data dari backend API (Pemicu muncul di Network Inspect)
    async function fetchAppData() {
      try {
        const [resBooks, resAuthors] = await Promise.all([
          fetch('/api/books').then(res => res.json()),
          fetch('/api/authors').then(res => res.json())
        ]);

        globalBooks = resBooks;
        globalAuthors = resAuthors;
        renderContent();
      } catch (error) {
        console.error('Gagal mengambil data API:', error);
        document.getElementById('main-container').innerHTML = `<p class="text-red-500 font-bold">Gagal memuat data dari server.</p>`;
      }
    }

    // Fungsi untuk mengganti tab tampilan
    function switchTab(tab) {
      currentTab = tab;
      
      // Atur style aktif pada tombol navigasi
      document.getElementById('btn-all').className = tab === 'all' ? 'bg-gray-900 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer' : 'bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer';
      document.getElementById('btn-books').className = tab === 'books' ? 'bg-blue-600 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer' : 'bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer';
      document.getElementById('btn-authors').className = tab === 'authors' ? 'bg-green-600 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer' : 'bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer';

      // Ubah teks judul kotak utama
      const boxTitle = document.getElementById('box-title');
      if (tab === 'books') boxTitle.innerText = 'Daftar Buku';
      else if (tab === 'authors') boxTitle.innerText = 'Daftar Penulis';
      else boxTitle.innerText = 'Semua Data (Buku & Penulis)';

      renderContent();
    }

    // Fungsi untuk merender HTML persis seperti style asli Anda
    function renderContent() {
      const container = document.getElementById('main-container');
      container.innerHTML = '';

      // 1. RENDER BAGIAN BUKU
      if (currentTab === 'all' || currentTab === 'books') {
        let booksSection = `<div class="space-y-4">`;
        if (currentTab === 'all') {
          booksSection += `<h3 class="font-bold text-lg text-gray-700">Daftar Buku</h3>`;
        }

        if (globalBooks.length === 0) {
          booksSection += `<p class="text-gray-500 text-sm italic">Tidak ada data buku.</p>`;
        } else {
          booksSection += `<ul class="space-y-4">`;
          globalBooks.forEach(book => {
            const author = globalAuthors.find(a => a.id === book.authorId);
            
            // Style asli buku Anda
            booksSection += `
              <li class="p-4 bg-gray-50 rounded-lg border border-gray-200 flex justify-between items-center shadow-sm">
                <div>
                  <span class="font-bold text-gray-800 text-lg">${book.title}</span>
                  ${currentTab === 'all' ? `
                    <span class="text-sm text-gray-600 block">Penulis: <span class="font-medium text-blue-600">${author ? author.name : 'Tidak Diketahui'}</span></span>
                  ` : ''}
                </div>
                <div class="flex items-center gap-2">
                  <a href="/buku/edit/${book.id}" class="bg-yellow-500 hover:bg-yellow-600 text-white text-xs px-3 py-1.5 rounded transition font-medium">Edit</a>
                  <button onclick="deleteBook('${book.id}')" class="bg-red-500 hover:bg-red-600 text-white text-xs px-3 py-1.5 rounded transition font-medium cursor-pointer">Hapus</button>
                </div>
              </li>
            `;
          });
          booksSection += `</ul>`;
        }
        booksSection += `</div>`;
        container.innerHTML += booksSection;
      }

      // 2. RENDER BAGIAN AUTHOR / PENULIS
      if (currentTab === 'all' || currentTab === 'authors') {
        let authorsSection = `<div class="space-y-4 mt-6">`;
        if (currentTab === 'all') {
          authorsSection += `<h3 class="font-bold text-lg text-gray-700">Daftar Penulis</h3>`;
        }

        if (globalAuthors.length === 0) {
          authorsSection += `<p class="text-gray-500 text-sm italic">Tidak ada data penulis.</p>`;
        } else {
          authorsSection += `<ul class="space-y-4">`;
          globalAuthors.forEach(author => {
            // Style asli author/penulis Anda
            authorsSection += `
              <li class="p-4 bg-gray-50 rounded-lg border border-gray-200 flex justify-between items-center shadow-sm">
                <div>
                  <span class="font-bold text-gray-800 text-lg">${author.name}</span>
                  <span class="text-xs text-gray-500 block mt-1">Data Penulis</span>
                </div>
                <div class="flex items-center gap-2">
                  <button onclick="alert('Fitur edit penulis')" class="bg-yellow-500 hover:bg-yellow-600 text-white text-xs px-3 py-1.5 rounded transition font-medium cursor-pointer">Edit</button>
                  <button onclick="deleteAuthor('${author.id}')" class="bg-red-500 hover:bg-red-600 text-white text-xs px-3 py-1.5 rounded transition font-medium cursor-pointer">Hapus</button>
                </div>
              </li>
            `;
          });
          authorsSection += `</ul>`;
        }
        authorsSection += `</div>`;
        container.innerHTML += authorsSection;
      }
    }

    // Fungsi Hapus Buku
    async function deleteBook(id) {
      if (!confirm('Yakin ingin menghapus buku ini?')) return;
      try {
        const response = await fetch(`/api/books/${id}`, { method: 'DELETE' });
        const result = await response.json();
        if (result.success || response.ok) {
          fetchAppData(); // Muat ulang data otomatis
        } else {
          alert('Gagal menghapus buku');
        }
      } catch (err) {
        console.error('Error:', err);
      }
    }

    // Fungsi Hapus Author (Sesuai dengan kode asli Anda)
    async function deleteAuthor(id) {
      if (confirm('Yakin ingin menghapus penulis ini?')) {
        try {
          const response = await fetch(`/api/authors/${id}`, { method: 'DELETE' });
          const result = await response.json();
          if (result.success) {
            fetchAppData(); // Muat ulang data otomatis
          } else {
            alert(result.message || 'Gagal menghapus penulis');
          }
        } catch (err) {
          console.error('Error:', err);
          alert('Terjadi kesalahan pada server');
        }
      }
    }

    // Panggil fungsi fetch pertama kali saat halaman dibuka
    fetchAppData();
  </script>

</body>
</html>