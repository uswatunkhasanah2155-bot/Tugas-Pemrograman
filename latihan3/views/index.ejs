<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Katalog Buku & Penulis</title>
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans p-6 min-h-screen">

  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <header class="mb-6 text-center">
      <h1 class="text-3xl font-bold text-blue-600">📚 Katalog Buku & Penulis</h1>
      <p class="text-gray-600">Integrasi EJS Template Engine & API Express.js</p>
    </header>

    <!-- Tombol Navigasi / Filter -->
    <div class="flex justify-center gap-3 mb-8">
      <button onclick="loadData('all')" class="bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer">
        Tampilkan Semua
      </button>
      <button onclick="loadData('books')" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer">
        Daftar Buku
      </button>
      <button onclick="loadData('authors')" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium shadow transition cursor-pointer">
        Daftar Penulis
      </button>
    </div>

    <!-- SATU KOTAK BESAR UTAMA -->
    <div class="bg-white p-6 rounded-lg shadow-md">
      
      <!-- Judul Kotak & Tombol Tambah Buku -->
      <div class="flex justify-between items-center mb-4 border-b pb-2">
        <h2 id="section-title" class="text-xl font-semibold text-purple-600">Semua Data (Buku & Penulis)</h2>
        <a href="/buku/tambah" class="bg-blue-600 hover:bg-blue-700 text-white text-xs px-3 py-2 rounded-lg font-medium transition shadow">
          + Tambah Buku
        </a>
      </div>
      
      <!-- Wadah Konten Dinamis yang akan diisi Fetch -->
      <div id="content-container" class="space-y-6">
        <p class="text-gray-500 italic">Memuat data dari API...</p>
      </div>

    </div>
  </div>

  <!-- SCRIPT FETCH AGAR MUNCUL DI NETWORK -->
  <script>
    let globalBooks = [];
    let globalAuthors = [];

    // Fungsi utama untuk mengambil data dari backend API
    async function fetchApiData() {
      try {
        const [resBooks, resAuthors] = await Promise.all([
          fetch('/api/books').then(res => res.json()),
          fetch('/api/authors').then(res => res.json())
        ]);

        globalBooks = resBooks;
        globalAuthors = resAuthors;

        // Tampilkan default (Semua data)
        renderContent('all');
      } catch (error) {
        console.error('Gagal memuat API:', error);
        document.getElementById('content-container').innerHTML = `<p class="text-red-600 font-bold">Gagal memuat data dari server.</p>`;
      }
    }

    // Fungsi untuk merender tampilan berdasarkan tombol yang diklik
    function renderContent(type) {
      const container = document.getElementById('content-container');
      const titleEl = document.getElementById('section-title');
      container.innerHTML = '';

      if (type === 'all' || type === 'books') {
        titleEl.innerText = type === 'books' ? 'Daftar Buku' : 'Semua Data (Buku & Penulis)';
        
        let booksHtml = '<div class="space-y-4"><h3 class="font-bold text-lg text-gray-700">Daftar Buku</h3>';
        if (globalBooks.length === 0) {
          booksHtml += '<p class="text-gray-500">Tidak ada buku.</p>';
        } else {
          globalBooks.forEach(book => {
            const author = globalAuthors.find(a => a.id === book.authorId);
            const authorName = author ? author.name : (book.authorName || 'Tidak diketahui');
            
            booksHtml += `
              <div class="p-4 border rounded-lg flex justify-between items-center bg-gray-50 shadow-sm">
                <div>
                  <h4 class="font-bold text-lg text-blue-600">${book.title}</h4>
                  <p class="text-sm text-gray-600">Penulis: <span class="font-medium text-gray-800">${authorName}</span></p>
                </div>
                <div class="flex gap-2">
                  <a href="/edit/${book.id}" class="bg-yellow-500 text-white px-3 py-1 rounded text-sm font-bold">Edit</a>
                  <button onclick="deleteBook(${book.id})" class="bg-red-500 text-white px-3 py-1 rounded text-sm font-bold cursor-pointer">Hapus</button>
                </div>
              </div>
            `;
          });
        }
        booksHtml += '</div>';
        container.innerHTML += booksHtml;
      }

      if (type === 'all' || type === 'authors') {
        if (type === 'authors') titleEl.innerText = 'Daftar Penulis';

        let authorsHtml = '<div class="space-y-4 mt-6"><h3 class="font-bold text-lg text-gray-700">Daftar Penulis</h3>';
        if (globalAuthors.length === 0) {
          authorsHtml += '<p class="text-gray-500">Tidak ada penulis.</p>';
        } else {
          globalAuthors.forEach(author => {
            authorsHtml += `
              <div class="p-4 border rounded-lg flex justify-between items-center bg-gray-50 shadow-sm">
                <div>
                  <h4 class="font-bold text-lg text-green-600">${author.name}</h4>
                  <p class="text-sm text-gray-500">Bio: ${author.bio || '-'}</p>
                </div>
                <div>
                  <button onclick="deleteAuthor(${author.id})" class="bg-red-500 text-white px-3 py-1 rounded text-sm font-bold cursor-pointer">Hapus</button>
                </div>
              </div>
            `;
          });
        }
        authorsHtml += '</div>';
        container.innerHTML += authorsHtml;
      }
    }

    // Fungsi Pengatur Tombol Navigasi
    function loadData(filterType) {
      renderContent(filterType);
    }

    // Fungsi Hapus Buku
    async function deleteBook(id) {
      if (confirm('Yakin ingin menghapus buku ini?')) {
        const response = await fetch(`/api/books/${id}`, { method: 'DELETE' });
        const result = await response.json();
        if (result.success) fetchApiData();
        else alert('Gagal menghapus buku');
      }
    }

    // Fungsi Hapus Penulis
    async function deleteAuthor(id) {
      if (confirm('Yakin ingin menghapus penulis ini?')) {
        const response = await fetch(`/api/authors/${id}`, { method: 'DELETE' });
        const result = await response.json();
        if (result.success) fetchApiData();
        else alert('Gagal menghapus penulis');
      }
    }

    // Panggil saat halaman pertama kali dibuka
    fetchApiData();
  </script>

</body>
</html>